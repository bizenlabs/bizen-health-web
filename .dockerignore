# Anything that doesn't need to enter the build context. Keeps `docker build`
# fast and avoids leaking host paths / secrets into image layers.

# Build outputs (we rebuild inside the image)
.next
out
build
dist

# Deps (we install inside the image)
node_modules

# VCS / IDE
.git
.gitignore
.github
.vscode
.idea

# Env / secrets — never copy into the image
.env
.env.*
!.env.example

# Local-only / dev tooling
.husky
.next-cache
coverage
*.log
.DS_Store

# Reference / docs
README.md
docs
AGENTS.md
CLAUDE.md
LICENSE
LICENSE.md

# Container artifacts (avoid recursive copy)
Dockerfile
.dockerignore

# Infra (CDK) — not needed inside the runtime image
infra
