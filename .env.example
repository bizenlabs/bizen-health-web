# Copy to .env.local and fill in real values. Do not commit .env.local.

# --- Public (exposed to browser) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- WorkOS (server-only) ---
# Dashboard: https://dashboard.workos.com
WORKOS_API_KEY=sk_test_replace_me
WORKOS_CLIENT_ID=client_replace_me
# AuthKit SDK reads this as the default redirectUri for session refresh
# and other internal flows. lib/workos.ts overrides it for sign-in/up.
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Signs/encrypts the AuthKit session cookie. Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=replace_with_32_plus_char_random_string

# WorkOS webhook signing secret (Settings -> Webhooks)
WORKOS_WEBHOOK_SECRET=whsec_replace_me

# --- Backend ---
SPRING_BASE_URL=http://localhost:8080
# Shared secret stamped on `X-Bizen-Webhook-Secret` when this BFF forwards
# verified WorkOS events to Spring Boot. Generate with: openssl rand -base64 32
# (must match `bizen.webhook.secret` on the BE.)
BIZEN_INTERNAL_WEBHOOK_SECRET=replace_with_32_plus_char_random_string
